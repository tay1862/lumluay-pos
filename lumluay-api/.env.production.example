# ═══════════════════════════════════════════════════════════════════════════════
# LUMLUAY API — Production Environment Variables
# Copy to .env and fill in every value marked  ← REQUIRED
# Generate secrets: openssl rand -base64 48
# ═══════════════════════════════════════════════════════════════════════════════

# ─── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
API_PREFIX=v1
LOG_LEVEL=info

# ─── Database ──────────────────────────────────────────────────────────────────
# ← REQUIRED  (service name 'postgres' resolves inside docker network)
DATABASE_URL=postgresql://lumluay:STRONG_DB_PASSWORD@postgres:5432/lumluay_db
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=STRONG_REDIS_PASSWORD          # ← REQUIRED

# ─── PostgreSQL (used by docker-compose) ────────────────────────────────────────
POSTGRES_USER=lumluay
POSTGRES_PASSWORD=STRONG_DB_PASSWORD          # ← REQUIRED — must match DATABASE_URL above
POSTGRES_DB=lumluay_db

# ─── JWT ───────────────────────────────────────────────────────────────────────
# ← REQUIRED  (run: openssl rand -base64 48)
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING
JWT_EXPIRES_IN=15m
# ← REQUIRED  (run: openssl rand -base64 48)
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_STRING
JWT_REFRESH_EXPIRES_IN=30d

# ─── Security ──────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ─── File Storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_MB=10

# ─── Super Admin (seeded on first run) ─────────────────────────────────────────
SUPER_ADMIN_USERNAME=superadmin             # ← REQUIRED
SUPER_ADMIN_PASSWORD=STRONG_ADMIN_PASSWORD  # ← REQUIRED

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (your domain)
CORS_ORIGINS=https://YOUR_DOMAIN,https://www.YOUR_DOMAIN

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT_DEFAULT=100
THROTTLE_LIMIT_AUTH=5

# ─── Domain (used by docker-compose certbot service) ───────────────────────────
DOMAIN=YOUR_DOMAIN                          # ← REQUIRED  e.g. pos.lumluay.com
CERTBOT_EMAIL=your@email.com               # ← REQUIRED  for Let's Encrypt expiry alerts
