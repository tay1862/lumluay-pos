# LUMLUAY API Environment Variables
# Copy this file to .env and fill in your values

# ─── App ───────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=v1

# ─── Database (PostgreSQL) ──────────────────────────────────────
DATABASE_URL=postgresql://lumluay:password@localhost:5432/lumluay_db
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ─── Redis ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-very-long-random-secret-key-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-this-to-another-very-long-random-secret
JWT_REFRESH_EXPIRES_IN=30d

# ─── Security ──────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ─── File Storage ──────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5

# ─── Super Admin ───────────────────────────────────────────────
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=change-in-production

# ─── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3001,http://localhost:8080

# ─── Rate Limiting ─────────────────────────────────────────────
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT_DEFAULT=100
THROTTLE_LIMIT_AUTH=5
